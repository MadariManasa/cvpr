import cv2
import numpy as np
import matplotlib.pyplot as plt
img = cv2.imread("image1.jpg")
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
cmy = 255 - img_rgb
hsv = cv2.cvtColor(img_rgb, cv2.COLOR_RGB2HSV)
plt.figure(figsize=(10,8))
plt.subplot(2,2,1) 
plt.title("RGB Image") 
plt.imshow(img_rgb) plt.axis("off")
plt.subplot(2,2,2)
plt.title("CMY Image")
plt.imshow(cmy) 
plt.axis("off") 
plt.subplot(2,2,3) 
plt.title("HSV Image") 
plt.imshow(hsv) 
plt.axis("off")
plt.show()
