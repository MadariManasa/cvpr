import cv2
import numpy as np

img = cv2.imread('image.png', 0)

bit_planes = []

for i in range(8):
    plane = (img >> i) & 1
    plane = plane * 255
    bit_planes.append(plane)

cv2.imshow("Original", img)

for i in range(8):
    cv2.imshow(f"Bit Plane {i}", bit_planes[i])

cv2.waitKey(0)
cv2.destroyAllWindows()
